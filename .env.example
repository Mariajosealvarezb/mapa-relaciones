# ============================================================
#  PLANTILLA DE LLAVES (variables de entorno) — Mapa de Relaciones
#  Copia este archivo como ".env.local" y rellena los valores.
#  El archivo .env.local NUNCA se sube a internet.
# ============================================================

# --- Supabase (base de datos) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Tabla donde se guardan las respuestas (default: respuestas_relaciones)
SUPABASE_TABLA=respuestas_relaciones

# --- Resend (correos) ---
RESEND_API_KEY=
# Remitente que verán tus seguidoras (debe ser de tu dominio verificado)
EMAIL_FROM="María José Álvarez B. <info@mariajosealvarezb.com>"

# --- Dirección pública de la app ---
# En tu computador: http://localhost:3000
# En producción: https://relaciones.mariajosealvarezb.com
APP_URL=http://localhost:3000

# --- Panel privado ---
PANEL_PASSWORD=

# --- API de Anthropic (diagnóstico del panel) ---
ANTHROPIC_API_KEY=
